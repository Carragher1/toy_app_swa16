
<div class="accordion" id="accordionExample">
<div class="accordion-item">
  <h2 class="accordion-header">
    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
      Why is my page not working?
    </button>
  </h2>
  <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#accordionExample">
    <div class="accordion-body">
      <strong>Have you tried restarting your app?</strong> This is a standard approach to getting programs to work!
    </div>
  </div>
</div>
  <div class="accordion-item">
    <h2 class="accordion-header">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
        Reach out to tech support!
      </button>
    </h2>
    <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
      <div class="accordion-body">
        <strong>Reach out through the about page. </strong> Contributors to this app are listed with contact links!
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- creates the body of the webage using container and modal bootstrap features. This creates a 
popup in reaction to a button click. Surprise! -->
<div class="container d-flex justify-content-center align-items-center vh-100">
<!-- button trigger modal -->
<button type="button" class="btn btn-danger btn-lg px-5 py-3 fw-bold" data-bs-toggle="modal" data-bs-target="#exampleModal">
   DONT CLICK
</button>

<!-- modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
   <div class="modal-dialog">
   <div class="modal-content">
       <div class="modal-header">
       <h1 class="modal-title fs-5" id="exampleModalLabel"> <i class="fas fa-camera"> </i>Gotcha!</h1>
       <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
       </div>
       <div class="modal-body">
       Have A Nice Day!
       </div>
       <div class="modal-footer">
       <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
       </div>
   </div>
   </div>
</div>
</div>

</body>
</html>
